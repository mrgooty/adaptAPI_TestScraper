# Copy to .env and adjust. All DB settings are optional — without Postgres
# the scraper/API/dashboard still work off output/scraped-data.json.

PORT=3000

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=express_app
DB_USER=your_postgres_user
DB_PASSWORD=
DB_SSL=false

# Optional overrides
# SCRAPED_DATA_PATH=./output/scraped-data.json   # where the dataset JSON lives
# DATABASE_URL=postgresql://user@host:5432/db    # used when NODE_ENV=production
# DB_LOGGING=true                                # log SQL statements
